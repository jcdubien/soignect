generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum ProfileType {
  REMPLACANT  // remplacement court terme, période définie
  ASSISTANT   // poste long terme (>= minMonths mois)
  TITULAIRE   // cabinet / titulaire
}

enum SwipeDirection {
  LEFT
  RIGHT
}

enum SubscriptionPlan {
  FREE
  PREMIUM    // 9€/mois — boost +5, accès scores remplaçants
  BOOST      // 29€/mois — boost +8, badge prioritaire, stats avancées
  STRUCTURE  // Structures privées — 89€/mois + 20€/contrat (metered, section 7)
}

enum MissionType {
  REMPLACEMENT
  ASSISTANAT
  COLLABORATION
}

enum ZonageType {
  NON_PRIORITAIRE  // Zone 4 ARS — offre élevée
  INTERMEDIAIRE    // Zone 3 ARS — offre intermédiaire
  SOUS_DOTEE       // Zone 2 ARS — autres professions/territoires
  TRES_SOUS_DOTEE  // Zone 1 ARS — désert médical
}

enum Profession {
  KINESITHERAPEUTE
  INFIRMIER
  ORTHOPHONISTE
  SAGE_FEMME
  MEDECIN
}

enum Region {
  GUADELOUPE
  SAINT_MARTIN
  SAINT_BARTH
  MARTINIQUE
  GUYANE
  REUNION
  MAYOTTE
  METROPOLE
}

enum PostType {
  TITULAIRE
  ASSOCIE
  ASSISTANT
  COLLABORATION
  REMPLACEMENT_REGULIER  // legacy — retiré du formulaire (section 5), conservé pour données existantes
}

// Nature d'un titulaire — distinction explicite Cabinet libéral vs Structure privée
// (EHPAD, clinique, SSR). Remplace le proxy isEmployeur pour la segmentation/billing.
enum TitulaireKind {
  CABINET
  STRUCTURE
}

enum BriqueStatus {
  // Titulaire (poste 1 auto)
  PRESENT
  ABSENT_CONGE
  ABSENT_MALADIE
  ABSENT_FORMATION
  // Poste assistant / collaborateur
  OCCUPE
  PREAVIS
  RECHERCHE
  NON_COUVERT
  FERME
  // Brique remplaçant ponctuel
  CONFIRME
  EN_ATTENTE
  ANNULE
  // Dates bloquées par le remplaçant (vacances, vie perso)
  INDISPONIBLE
}

// Statut d'une mise en relation (section 12 recettage)
enum MatchStatus {
  EN_ATTENTE
  DISCUSSION
  CONFIRME
  DECLINE
  EXPIRE
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  role             Role      @default(USER)
  profile          Profile?
  resetToken       String?
  resetTokenExpiry DateTime?
  activeProfileId  String?
  // Notifications (section 50-51)
  phone            String?
  phoneCountry     String?   @default("GP")
  whatsappOptIn    Boolean   @default(false)
  emailOptIn       Boolean   @default(true)
  // Opt-out par type (section notifications recruteur) — la consultation d'annonce
  // est fréquente : on la coupe indépendamment du consentement email global.
  notifyConsultation Boolean @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// Identité professionnelle — pas de dates ici
model Profile {
  id       String      @id @default(cuid())
  userId   String      @unique
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type     ProfileType
  name     String?     // Nom du cabinet ou du professionnel
  photoUrl String?
  // Photos secondaires optionnelles (section 3) — jusqu'à 2
  secondaryPhotoUrl1 String?
  secondaryPhotoUrl2 String?
  bio      String?     @db.VarChar(300)
  bioTinder String?    @db.VarChar(280)  // "Je suis / Je cherche / J'aspire à"

  // Géographie & profession
  profession           Profession @default(KINESITHERAPEUTE)
  region               Region     @default(GUADELOUPE)
  zonage               ZonageType?
  institutionalPartner Boolean    @default(false) // CPTS / ARS / Collectivité

  // Pondération feed
  weight    Float     @default(1.0)
  isPaid    Boolean   @default(false)
  paidUntil DateTime?

  // Désirabilité & abonnement
  desirabilityScore    Float            @default(0)     // 0 à 10 — composante du score d'affinité
  desirabilityOverride Float?                           // Override admin (priorité absolue)
  desirabilityExpiry   DateTime?                        // Expiration du boost manuel
  subscriptionPlan     SubscriptionPlan @default(FREE)
  isFounding           Boolean          @default(false) // Cabinet fondateur = score 10 permanent

  // Stripe — pour le metered billing des structures (section 7)
  stripeCustomerId     String?
  stripeSubscriptionId String?

  // Bascule individuelle vers le payant (section 99/100) — date d'atteinte d'un des 2
  // critères (contrat signé OU usage soutenu). Renseigné = plus couvert par le mode gratuit
  // global (après période de grâce). Null = couvert par freeAccessMode tant qu'actif.
  billingTriggeredAt   DateTime?

  // Notation agrégée (mise à jour à chaque Rating)
  ratingAvg   Float?
  ratingCount Int    @default(0)

  // Flexibilité sur les dates (0=exact, 1=±3j, 2=±1sem, 3=±2sem, 4=±1mois)
  dateFlexibility Int @default(0)

  // Recherche de logement (section 120) — signal structuré du remplaçant pour le
  // bonus logement du score d'affinité (match binaire avec Mission.logementPropose).
  rechercheLogement Boolean @default(false)

  // Vérification RPPS via API ANS (section 30)
  isVerified  Boolean @default(false)

  // Identité contractuelle (section 150) — injectée dans le PDF de contrat, obligatoire
  // avant génération. Praticiens : rpps + numeroOrdre + adresse. Structures : siret + adresse.
  rpps        String?
  numeroOrdre String?
  adresse     String?
  siret       String?

  // Établissement employeur : terminologie CDI/CDD/Vacation (section 37)
  isEmployeur Boolean @default(false)
  // Distinction explicite Cabinet/Structure (segmentation & billing, section 7/99)
  titulaireKind TitulaireKind @default(CABINET)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  missions                  Mission[]
  swipesGiven               Swipe[]          @relation("SwiperProfile")
  ratingsGiven              Rating[]         @relation("RaterProfile")
  ratingsReceived           Rating[]         @relation("RatedProfile")
  messagesSent              Message[]
  matchesA                  Match[]          @relation("MatchProfileA")
  matchesB                  Match[]          @relation("MatchProfileB")
  cabinetRatingsGiven       CabinetRating[]  @relation("CabinetRatingRater")
  cabinetRatingsReceived    CabinetRating[]  @relation("CabinetRatingRated")
  remplacantRatingsGiven    RemplacantRating[] @relation("RemplacantRatingRater")
  remplacantRatingsReceived RemplacantRating[] @relation("RemplacantRatingRated")
  cabinetPosts              CabinetPost[]    @relation("CabinetPosts")

  @@index([type, isActive])
}

// Une annonce = une mission (plusieurs par profil possible)
model Mission {
  id          String   @id @default(cuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  location    String
  specialties String[]

  // Phrase libre (280 signes) — ex: "Je recherche un cabinet sport en Guadeloupe"
  pitch     String? @db.VarChar(280)
  bioTinder String? @db.VarChar(280)  // Bio spécifique à cette annonce

  // REMPLACANT / TITULAIRE (remplacement) : dates définies
  startDate DateTime?
  endDate   DateTime?

  // ASSISTANT : durée minimale en mois (ex: 3, 6, 12)
  minMonths Int?

  // REMPLACANT : taux de rétrocession souhaité (%)
  retrocessionRate Int?

  // Type de contrat (section 20 — 3 types)
  missionType MissionType @default(REMPLACEMENT)

  // Zonage ARS (calculé depuis la commune à la création)
  zonage ZonageType?

  // Macro-zones géographiques souhaitées / couvertes (section 138) — multi-sélection.
  // La commune (location) reste l'ancre précise (contrat PDF, zonage ARS, affichage) ;
  // ces zones élargissent la zone de recherche pour le score d'affinité géo.
  zones ZoneGeographique[] @default([])

  // Distribution Facebook (section 12)
  facebookPostId   String?
  facebookPostedAt DateTime?
  autoPostFacebook Boolean   @default(true)

  // Flexibilité sur les dates (0=exact, 1=±3j, 2=±1sem, 3=±2sem, 4=±1mois)
  dateFlexibility Int @default(0)

  // Logement proposé avec l'annonce (section 120) — bonus logement du score d'affinité
  // (match binaire avec Profile.rechercheLogement du remplaçant).
  logementPropose Boolean @default(false)

  // Lien Planning Board (section 28)
  cabinetPostId String?
  cabinetPost   CabinetPost? @relation("PostMissions", fields: [cabinetPostId], references: [id])
  singleSlot    Boolean      @default(false)
  maxCandidates Int          @default(10)

  // Statut manuel de la brique Planning Board (section 33)
  briqueStatus    BriqueStatus @default(RECHERCHE)
  statusUpdatedAt DateTime?
  statusNote      String?      @db.VarChar(200)

  // Nom du remplaçant/successeur matché — affiché sur le segment RECRUTEMENT/CONFIRME (section 1c / 6)
  matchedName     String?      @db.VarChar(120)

  // Date de départ prévue — déclencheur silencieux Confirmé → Recrutement/Non couvert (section 6)
  departureDate   DateTime?

  // Planning Board section 43 — déclaration de vacance titulaire
  isSelfPresence Boolean @default(false)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  swipesReceived Swipe[] @relation("SwipedMission")
  matchesA       Match[] @relation("MatchMissionA")
  matchesB       Match[] @relation("MatchMissionB")

  @@index([profileId, isActive])
  @@index([location, isActive])
}

// Macro-zones géographiques Guadeloupe (section 138) — palier intermédiaire
// avant l'architecture temps de trajet national (section 135).
enum ZoneGeographique {
  CENTRE_CAP_EXCELLENCE
  SUD_GRANDE_TERRE
  NORD_GRANDE_TERRE
  SUD_BASSE_TERRE
  NORD_BASSE_TERRE
  MARIE_GALANTE
  LES_SAINTES
  LA_DESIRADE
  SAINT_MARTIN
  SAINT_BARTHELEMY
}

// Table de correspondance commune → zone (mapping figé, section 138).
// Le mapping applicatif de référence vit dans src/lib/communes.ts (COMMUNE_ZONE) ;
// cette table le matérialise en base pour d'éventuelles analyses SQL par zone
// (ex: futur TensionScore par zone, sections 82-84).
model CommuneZone {
  commune String           @id
  zone    ZoneGeographique
}

// Un profil swipe sur une mission (pas un autre profil)
model Swipe {
  id              String         @id @default(cuid())
  swiperId        String
  swiper          Profile        @relation("SwiperProfile", fields: [swiperId], references: [id])
  swipedMissionId String
  swipedMission   Mission        @relation("SwipedMission", fields: [swipedMissionId], references: [id])
  direction       SwipeDirection
  affinityScore   Float?                         // Score total 0-100 calculé par DeepSeek
  scoreDetails    Json?                          // {dates, geo, specialty, bio, desirability}
  createdAt       DateTime       @default(now())

  @@unique([swiperId, swipedMissionId])
}

// Match entre deux profils, déclenché par deux missions
model Match {
  id         String   @id @default(cuid())
  profileAId String
  profileA   Profile  @relation("MatchProfileA", fields: [profileAId], references: [id])
  profileBId String
  profileB   Profile  @relation("MatchProfileB", fields: [profileBId], references: [id])
  missionAId String?
  missionA   Mission? @relation("MatchMissionA", fields: [missionAId], references: [id])
  missionBId String?
  missionB   Mission? @relation("MatchMissionB", fields: [missionBId], references: [id])
  aiScore           Float?
  aiFactors         Json?
  status            MatchStatus @default(EN_ATTENTE)
  ratings           Rating[]
  cabinetRatings    CabinetRating[]
  remplacantRatings RemplacantRating[]
  messages          Message[]
  createdAt         DateTime @default(now())

  // Signature par photo (section 61) — chemin Storage bucket "signatures" (non public)
  signatureTitulaireUrl   String?
  signatureTitulaireAt    DateTime?
  signatureRemplacantUrl  String?
  signatureRemplacantAt   DateTime?

  @@unique([profileAId, profileBId])
}

model Message {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  senderId  String
  sender    Profile  @relation(fields: [senderId], references: [id])
  content   String   @db.VarChar(1000)
  createdAt DateTime @default(now())
  // Rappel 24h envoyé pour ce message resté sans réponse (section 9) — évite les doublons
  reminderSentAt DateTime?

  @@index([matchId, createdAt])
}

model Rating {
  id        String   @id @default(cuid())
  raterId   String
  rater     Profile  @relation("RaterProfile", fields: [raterId], references: [id])
  ratedId   String
  rated     Profile  @relation("RatedProfile", fields: [ratedId], references: [id])
  matchId   String?
  match     Match?   @relation(fields: [matchId], references: [id])
  score     Int
  comment   String?  @db.VarChar(500)
  createdAt DateTime @default(now())

  @@unique([raterId, ratedId, matchId])
}

// Notation d'un cabinet par un remplaçant (publique)
model CabinetRating {
  id           String   @id @default(cuid())
  raterId      String   // REMPLACANT qui note
  rater        Profile  @relation("CabinetRatingRater", fields: [raterId], references: [id])
  ratedId      String   // TITULAIRE noté
  rated        Profile  @relation("CabinetRatingRated", fields: [ratedId], references: [id])
  matchId      String?
  match        Match?   @relation(fields: [matchId], references: [id])
  recommended  Boolean  // true = recommande, false = ne recommande pas
  // Critères détaillés — optionnels (remplis si l'utilisateur veut préciser)
  scoreAccueil   Int?
  scoreMateriel  Int?
  scoreContrat   Int?
  scoreAmbiance  Int?
  scoreGlobal    Float?  // calculé si critères renseignés, sinon null
  comment      String?  @db.VarChar(500)
  // Modération : false = en attente de validation admin avant affichage public
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([raterId, ratedId, matchId])
}

// Évaluation d'un remplaçant par un cabinet (privée)
model RemplacantRating {
  id           String   @id @default(cuid())
  raterId      String   // TITULAIRE qui évalue
  rater        Profile  @relation("RemplacantRatingRater", fields: [raterId], references: [id])
  ratedId      String   // REMPLACANT évalué
  rated        Profile  @relation("RemplacantRatingRated", fields: [ratedId], references: [id])
  matchId      String?
  match        Match?   @relation(fields: [matchId], references: [id])
  recommended         Boolean  // true = recommande, false = ne recommande pas
  // Critères détaillés — optionnels (PAS de commentaire — art. R.4321-99)
  scorePonctualite    Int?
  scoreQualiteSoins   Int?
  scoreDossierPatient Int?
  scoreCommunication  Int?
  scoreGlobal         Float?
  createdAt    DateTime @default(now())

  @@unique([raterId, ratedId, matchId])
}

// Données APL DREES par commune — section 22
// Alimenté par scripts/update_apl.py (cron annuel)
model CommuneAPL {
  id                  Int      @id @default(autoincrement())
  codeInsee           String   @unique
  commune             String
  departement         String
  aplKine             Float?
  aplInfirmier        Float?
  aplMedecin          Float?
  aplSageFemme        Float?
  aplOrthophoniste    Float?
  boostKine           Int      @default(0)
  boostInfirmier      Int      @default(0)
  boostMedecin        Int      @default(0)
  boostSageFemme      Int      @default(0)
  boostOrthophoniste  Int      @default(0)
  updatedAt           DateTime @default(now()) @updatedAt
}

// Poste du Planning Board (section 28) — un poste = une ligne de timeline
model CabinetPost {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  cabinetId    String
  cabinet      Profile   @relation("CabinetPosts", fields: [cabinetId], references: [id])
  label        String    // "Poste 1", "Dr Marie L.", etc.
  postType     PostType  @default(REMPLACEMENT_REGULIER)
  maxSlots     Int       @default(1)
  noticeMonths Int       @default(3)
  autoAlert    Boolean   @default(true)
  autoPublish  Boolean   @default(false)
  isActive     Boolean   @default(true)
  missions     Mission[] @relation("PostMissions")
}

// Back-office de traçabilité (section 86) — table d'événements horodatés, écrite
// en parallèle des tables métier pour l'analyse statistique future (pitch ARS/CGSS).
// Alimentée par de simples inserts fire-and-forget dans les routes existantes.
model TraceEvent {
  id          String   @id @default(cuid())
  eventType   String   // "MISSION_PUBLISHED", "SWIPE_RIGHT", "MATCH_CREATED", "CONTRACT_SIGNED", "PLANNING_ACTIVE", ...
  missionId   String?
  matchId     String?
  profileId   String?  // acteur (ex: cabinet actif sur le Planning Board — section 100 critère 2)
  commune     String?  // dénormalisé pour agrégation géographique sans jointures
  profession  String?
  missionType String?
  occurredAt  DateTime @default(now())
  metadata    Json?

  @@index([eventType, commune, occurredAt])
  @@index([commune, profession, occurredAt])
  @@index([profileId, eventType, occurredAt])
}

// Configuration plateforme (singleton) — mode lancement gratuit (section 2).
// Tant que freeAccessMode = true, tous les comptes ont accès au Premium.
model PlatformConfig {
  id             String   @id @default(cuid())
  freeAccessMode Boolean  @default(true)
  // Blocage dur des contrats si identité contractuelle incomplète (section 150).
  // false = phase d'avertissement (non bloquant) ; true = accès contrat refusé si incomplet.
  enforceContractProfile Boolean @default(false)
  updatedAt      DateTime @updatedAt
}
